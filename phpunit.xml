<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_KEY" value="base64:V6LzEqLhfwQkQ3FI6ZndfA8YVJ5L7j1N3JY8r0h+1yE="/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="DB_URL" value=""/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <!-- Isolate tests from the production Redis keyspace (queues/caches/
             alert buffers live in db 0/1). Same philosophy as the sqlite DB
             guard: a test must never touch live data. -->
        <env name="REDIS_DB" value="13"/>
        <env name="REDIS_CACHE_DB" value="14"/>
        <env name="REDIS_PREFIX" value="serfix-testing-"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
        <env name="RECAPTCHA_SITE_KEY" value=""/>
        <env name="RECAPTCHA_SECRET_KEY" value=""/>
        <!-- Blank the real provider key so tests can NEVER hit (and bill) the
             live Keywords Everywhere API. QUEUE_CONNECTION=sync runs
             RankTrackingKeywordObserver's FetchKeywordMetricsJob inline, so a
             leaked key means every RankTrackingKeyword::create() in a test
             makes a real credit-billed HTTP call (found 2026-07-11). Same
             philosophy as the REDIS_DB pin above. -->
        <env name="KEYWORDS_EVERYWHERE_API_KEY" value=""/>
        <env name="SERPER_API_KEY" value=""/>
        <!-- Same rule for the LLM providers: a leaked key would let any test
             that resolves LlmClient (or validates the admin settings form,
             which fetches the live /models list) make real network calls —
             completions are token-billed. Tests that need HTTP use
             Http::fake() and set a fake key via config(). -->
        <env name="MISTRAL_API_KEY" value=""/>
        <env name="DEEPSEEK_API_KEY" value=""/>
        <env name="IDEOGRAM_API_KEY" value=""/>
        <!-- Spend breakers off by default in tests (prod .env now carries real
             caps; the spend Redis key accumulates across runs in the pinned
             test db). Tests that exercise a breaker set config() explicitly. -->
        <env name="CONTENT_LLM_MONTHLY_CAP_USD" value=""/>
        <env name="IDEOGRAM_MONTHLY_CAP_USD" value=""/>
        <!-- Prod .env hides the Content UI (operator gate); tests exercise it. -->
        <env name="CONTENT_AUTOPILOT_UI" value="true"/>
        <!-- Image STORAGE, same leak class as the API keys above (found
             2026-07-21): phpunit pins only what it overrides, so
             CONTENT_IMAGES_DISK=content_s3 leaked from prod .env and
             GenerateContentImagesJob wrote test images into the REAL Hetzner
             bucket — while ContentImagesTest asserted against Storage::fake
             ('public') and "failed" for the wrong reason. Pin the disk to
             public and blank the creds so a stray write can never reach prod
             storage. Never remove. -->
        <env name="CONTENT_IMAGES_DISK" value="public"/>
        <env name="CONTENT_S3_KEY" value=""/>
        <env name="CONTENT_S3_SECRET" value=""/>
        <env name="CONTENT_S3_BUCKET" value=""/>
        <env name="CONTENT_S3_ENDPOINT" value=""/>
        <env name="CONTENT_S3_URL" value=""/>
        <!-- Same rule for the Site Explorer report providers (found again
             2026-07-14: a plain GET /backlinks in a test dispatched a REAL
             billed DataForSEO generation via QUEUE_CONNECTION=sync, because
             these creds leaked from prod .env). Blank creds make
             DataForSeoBacklinkClient::isConfigured() false, so report
             controllers/jobs no-op; tests that need the pipeline mock the
             clients or Http::fake() with config() overrides. -->
        <env name="DATAFORSEO_LOGIN" value=""/>
        <env name="DATAFORSEO_PASSWORD" value=""/>
        <env name="MOZ_API_TOKEN" value=""/>
        <env name="MOZ_ACCESS_ID" value=""/>
        <env name="MOZ_SECRET_KEY" value=""/>
        <env name="OPENPAGERANK_API_KEY" value=""/>
    </php>
</phpunit>
